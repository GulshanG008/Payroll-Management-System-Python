# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.env/
.venv/

# IDE settings
.vscode/
.idea/

# OS junk files
.DS_Store
Thumbs.db

# Logs
*.log

# MySQL unwanted files
*.sql~
