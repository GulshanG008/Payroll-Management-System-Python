*.backup.sql

# Local MySQL config (if created)
mysql.cnf
my.cnf

# Reports generated by your system
reports/payslips/*.pdf
reports/summaries/*.pdf

# Environment files (if using DB passwords)
.env
*.env

# Build artifacts (future packaging)
dist/
build/
